# Public site URL (required for Open Graph, sitemap, canonical metadata)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── Contact form (developer sets up once — client does nothing) ───

# Option B — Resend (you add keys in Vercel; client only reads their inbox)
CONTACT_TO_EMAIL=contact@kre8.ch
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Your Agency Name <onboarding@resend.dev>

# If both are set, Formspree is used first.
